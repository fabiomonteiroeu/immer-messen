# Local dev defaults. In production (EasyPanel) override via service env vars.
# Production CORS must include the public frontend origin:
#   CORS_ALLOWED_ORIGINS=https://immer.fabiomonteiro.cloud
# Production webhook target (internal between EasyPanel services):
#   WEB_REVALIDATE_URL=http://<easypanel-web-service-name>:3000/api/revalidate
# Database in EasyPanel: use the Postgres service "Internal Host", e.g.
#   DATABASE_HOST=immer-messen_db  (depends on project/service names)
#   DATABASE_SSL=false (internal network)

HOST=0.0.0.0
PORT=1337
APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
API_TOKEN_SALT=replace-with-api-token-salt
ADMIN_JWT_SECRET=replace-with-admin-jwt-secret
TRANSFER_TOKEN_SALT=replace-with-transfer-token-salt
JWT_SECRET=replace-with-jwt-secret
ADMIN_ENCRYPTION_KEY=replace-with-admin-encryption-key
DATABASE_CLIENT=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=immer_messen
DATABASE_USERNAME=immer
DATABASE_PASSWORD=replace-with-postgres-password
DATABASE_SSL=false
STRAPI_WEBHOOK_TOKEN=replace-with-strapi-webhook-token
WEB_REVALIDATE_URL=http://web:3000/api/revalidate
REVALIDATE_SECRET=replace-with-revalidate-secret
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_CONCURRENT_LIMIT=2
UPLOAD_DENIED_MIME=image/svg+xml
CORS_ALLOWED_ORIGINS=http://localhost:3000
