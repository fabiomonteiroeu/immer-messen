{
  "kind": "collectionType",
  "collectionName": "case_studies",
  "info": {
    "singularName": "case-study",
    "pluralName": "case-studies",
    "displayName": "Case Study",
    "description": "Technical case studies for industry use cases"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "maxLength": 120,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "summary": {
      "type": "text",
      "required": true,
      "maxLength": 320,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "sectorCategory": {
      "type": "string",
      "maxLength": 80,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "heroMedia": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images", "videos", "files"]
    },
    "client": {
      "type": "string",
      "maxLength": 120
    },
    "startDate": {
      "type": "date"
    },
    "duration": {
      "type": "string",
      "maxLength": 60,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "tags": {
      "type": "string",
      "maxLength": 255,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "projectLogos": {
      "type": "component",
      "repeatable": true,
      "component": "case.project-logo",
      "max": 3
    },
    "body": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "applicationAreas": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::application-area.application-area",
      "inversedBy": "caseStudies"
    },
    "relatedCases": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::case-study.case-study"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
