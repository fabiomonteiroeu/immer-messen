    "contactDetails": {
      "type": "component",
      "repeatable": false,
      "component": "shared.contact-details"
    },
    "copyrightText": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "privacyLink": {
      "type": "component",
      "repeatable": false,
      "component": "shared.link-item",
      "pluginOptions": {
        "i18n": {
          "localized": true
