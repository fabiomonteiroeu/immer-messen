{
  "kind": "collectionType",
  "collectionName": "contact_submissions",
  "info": {
    "singularName": "contact-submission",
    "pluralName": "contact-submissions",
    "displayName": "Contact Submission",
    "description": "Messages submitted from the public contact form"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": false
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "company": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "message": {
      "type": "text",
      "required": true
    },
    "localeCode": {
      "type": "enumeration",
      "enum": ["pt-BR", "en", "es"],
      "required": true
    },
    "sourcePage": {
      "type": "string"
    },
    "consentAccepted": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "enumeration",
      "enum": ["new", "contacted", "archived"],
      "default": "new"
    }
  }
}
