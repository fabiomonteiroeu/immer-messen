{
  "kind": "singleType",
  "collectionName": "global_settings",
  "info": {
    "singularName": "global-setting",
    "pluralName": "global-settings",
    "displayName": "Global Setting",
    "description": "Global site settings and identity assets"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "primaryLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "alternativeLogo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "contactDetails": {
      "type": "component",
      "repeatable": false,
      "component": "shared.contact-details"
    },
    "socialLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.social-link",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "allowedScripts": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    }
  }
}
