# Local dev defaults. In production (EasyPanel) override via service env vars.
# Production examples (see DEPLOY.md):
#   NEXT_PUBLIC_SITE_URL=https://immer.fabiomonteiro.cloud
#   NEXT_PUBLIC_STRAPI_URL=https://cms.fabiomonteiro.cloud
#   INTERNAL_STRAPI_URL=http://<easypanel-cms-service-name>:1337

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SUPPORTED_LOCALES=pt-BR,en,es
INTERNAL_STRAPI_URL=http://cms:1337
PREVIEW_SECRET=replace-with-preview-secret
REVALIDATE_SECRET=replace-with-revalidate-secret
NEXT_PUBLIC_ELFSIGHT_LINKEDIN_WIDGET_ID=
