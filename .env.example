# Shared project metadata
COMPOSE_PROJECT_NAME=immer-messen

# Public URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Internal service URLs
INTERNAL_STRAPI_URL=http://cms:1337
STRAPI_WEBHOOK_REVALIDATE_URL=http://web:3000/api/revalidate

# Locale defaults
NEXT_PUBLIC_DEFAULT_LOCALE=pt-BR
NEXT_PUBLIC_SUPPORTED_LOCALES=pt-BR,en,es

# Preview and revalidation
PREVIEW_SECRET=replace-with-preview-secret
REVALIDATE_SECRET=replace-with-revalidate-secret
STRAPI_WEBHOOK_TOKEN=replace-with-strapi-webhook-token

# Database
POSTGRES_DB=immer_messen
POSTGRES_USER=immer
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_PORT=5432

# Strapi runtime
STRAPI_PORT=1337
STRAPI_HOST=0.0.0.0
STRAPI_APP_KEYS=replace-me-1,replace-me-2,replace-me-3,replace-me-4
STRAPI_API_TOKEN_SALT=replace-with-api-token-salt
STRAPI_ADMIN_JWT_SECRET=replace-with-admin-jwt-secret
STRAPI_TRANSFER_TOKEN_SALT=replace-with-transfer-token-salt
STRAPI_JWT_SECRET=replace-with-jwt-secret
STRAPI_ADMIN_ENCRYPTION_KEY=replace-with-admin-encryption-key

# Upload and security policies
UPLOAD_MAX_FILE_SIZE_MB=50
UPLOAD_CONCURRENT_LIMIT=2
UPLOAD_ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp,image/avif
UPLOAD_ALLOWED_VIDEO_MIME=video/mp4,video/webm
UPLOAD_DENIED_MIME=image/svg+xml
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Contact flow placeholders
CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=60000
CONTACT_HONEYPOT_FIELD=website
